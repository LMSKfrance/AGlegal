# Auth (required for admin)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=your-secret-at-least-32-characters-long
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Turso database (required for persistent storage on Netlify)
# 1. Create a free account at https://turso.tech
# 2. Install CLI: curl -sSfL https://get.tur.so/install.sh | bash
# 3. Create DB: turso db create ag-legal
# 4. Get URL:   turso db show ag-legal --url
# 5. Get token: turso db tokens create ag-legal
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
